generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

enum AgentType {
  SOFTWARE_ENGINEER
  CTO
  SALES_DEV_REP
  SUPPORT_AGENT
  RESEARCH_ANALYST
  PROJECT_MANAGER
  CONTENT_WRITER
  DEVOPS_ENGINEER
  HR_MANAGER
  BOOKKEEPER
  DESIGN_LEAD
  GROWTH_MARKETER
}

enum AgentStatus {
  ACTIVE
  PAUSED
  OFFLINE
}

enum ConversationStatus {
  OPEN
  CLOSED
  ARCHIVED
}

enum LLMModel {
  GPT_4O
  CLAUDE
  GEMINI
  DEEPSEEK
  LLAMA
}

enum Channel {
  SLACK
  DISCORD
  TELEGRAM
  WHATSAPP
  EMAIL
}

enum SubscriptionTier {
  PRO
  TEAM
  BUSINESS
  AGENCY
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  TRIALING
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  password     String?
  name         String
  googleId     String?       @unique
  avatarUrl    String?
  role         UserRole      @default(USER)
  agents         Agent[]
  subscription   Subscription?
  passwordResets PasswordReset[]
  createdAt      DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Agent {
  id            String        @id @default(uuid())
  name          String
  type          AgentType
  status        AgentStatus   @default(OFFLINE)
  config        Json          @default("{}")
  model         LLMModel      @default(GPT_4O)
  channel       Channel       @default(EMAIL)
  instructions  String?       @db.Text
  brandVoice    String?       @db.Text
  approvalGate  Boolean       @default(false)
  taskCount     Int           @default(0)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  conversations Conversation[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Conversation {
  id        String             @id @default(uuid())
  agent     Agent              @relation(fields: [agentId], references: [id], onDelete: Cascade)
  agentId   String
  messages  Json               @default("[]")
  status    ConversationStatus @default(OPEN)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
}

model Subscription {
  id               String             @id @default(uuid())
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           String             @unique
  tier             SubscriptionTier   @default(PRO)
  billingCycle     BillingCycle       @default(MONTHLY)
  status           SubscriptionStatus @default(ACTIVE)
  agentLimit       Int                @default(3)
  currentPeriodEnd DateTime
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model PasswordReset {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
}

model ContactSubmission {
  id        String   @id @default(uuid())
  name      String
  email     String
  company   String?
  message   String   @db.Text
  type      String   @default("sales")
  createdAt DateTime @default(now())
}
